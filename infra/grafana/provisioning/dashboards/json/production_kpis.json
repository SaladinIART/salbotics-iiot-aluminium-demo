{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.5.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Multi-site production KPIs — availability, quality, active alerts per asset",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Site: $site",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green",  "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Availability % (8h)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
          "format": "table",
          "rawSql": "SELECT asset AS \"Asset\", ROUND(availability::numeric * 100, 1) AS \"Availability %\" FROM v_kpi_summary WHERE site = '$site' ORDER BY asset",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green",  "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Quality Rate % (8h)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
          "format": "table",
          "rawSql": "SELECT asset AS \"Asset\", ROUND(quality_rate::numeric * 100, 1) AS \"Quality %\" FROM v_kpi_summary WHERE site = '$site' ORDER BY asset",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",   "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Open Alerts per Asset",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
          "format": "table",
          "rawSql": "SELECT asset AS \"Asset\", open_alert_count AS \"Open Alerts\" FROM v_kpi_summary WHERE site = '$site' ORDER BY asset",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Availability %" }, "properties": [ { "id": "unit", "value": "percent" } ] },
          { "matcher": { "id": "byName", "options": "Quality %" },      "properties": [ { "id": "unit", "value": "percent" } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "title": "Asset KPI Table",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
          "format": "table",
          "rawSql": "SELECT asset AS \"Asset\", display_name AS \"Name\", asset_type AS \"Type\", ROUND(availability::numeric*100,1) AS \"Availability %\", ROUND(quality_rate::numeric*100,1) AS \"Quality %\", ROUND(running_minutes::numeric,0) AS \"Running (min)\", ROUND(fault_minutes::numeric,0) AS \"Fault (min)\", open_alert_count AS \"Open Alerts\" FROM v_kpi_summary WHERE site = '$site' ORDER BY asset",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["iiot", "kpi", "production"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "demo-site", "value": "demo-site" },
        "datasource": { "type": "postgres", "uid": "iiot-timescaledb" },
        "definition": "SELECT site_id FROM sites WHERE active = true ORDER BY site_id",
        "hide": 0,
        "includeAll": false,
        "label": "Site",
        "multi": false,
        "name": "site",
        "options": [],
        "query": "SELECT site_id FROM sites WHERE active = true ORDER BY site_id",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-8h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Production KPIs",
  "uid": "nexus-production-kpis",
  "version": 1
}
