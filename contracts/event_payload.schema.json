{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventPayload",
  "type": "object",
  "required": [
    "v",
    "ts",
    "source_ts",
    "asset",
    "event_type",
    "state",
    "fault_code",
    "severity",
    "message",
    "seq"
  ],
  "properties": {
    "v": {
      "type": "integer",
      "const": 1
    },
    "ts": {
      "type": "integer",
      "minimum": 0
    },
    "source_ts": {
      "type": "integer",
      "minimum": 0
    },
    "asset": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": ["state_changed", "alarm_raised", "alarm_cleared", "maintenance_started", "maintenance_ended", "status"]
    },
    "state": {
      "type": "string",
      "enum": ["RUNNING", "IDLE", "STARTUP", "FAULTED", "MAINTENANCE"]
    },
    "fault_code": {
      "type": "integer",
      "minimum": 0
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "critical"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "reason_code": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
