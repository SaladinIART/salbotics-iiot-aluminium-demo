# ─── MQTT BROKER ─────────────────────────────────────────────────────────────
MQTT_USER=iiot
MQTT_PASSWORD=demo_password
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_CLIENT_ID_PREFIX=iiot-demo

# ─── TIMESCALEDB (PostgreSQL) ─────────────────────────────────────────────────
POSTGRES_USER=iiot
POSTGRES_PASSWORD=iiot_password_change_me
POSTGRES_DB=iiot
PGHOST=timescaledb
PGPORT=5432
PGDATABASE=iiot
PGUSER=iiot
PGPASSWORD=iiot_password_change_me

# ─── COLLECTOR ────────────────────────────────────────────────────────────────
# ISA-95 hierarchy: site / line / asset
SITE=demo-site
LINE=aluminium-profile-line-1
ASSET_ID=press-01
MODBUS_HOST=modbus_sim
MODBUS_PORT=1502
MODBUS_UNIT_ID=1
COLLECT_INTERVAL_MS=1000

# ─── GRAFANA ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_now

# ─── REST API (Phase 3) ───────────────────────────────────────────────────────
# API key sent in X-API-Key header. Change before any deployment.
API_KEY=nexus-dev-key-change-me
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins (use * for local dev only)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ─── ALERT ENGINE (Phase 2) ───────────────────────────────────────────────────
# Suppress duplicate (asset, signal, alert_type) alerts within this window (seconds)
ALERT_DEDUP_WINDOW_SEC=300
# Optional webhook URL for Teams / Slack alert notifications (leave blank to disable)
ALERT_WEBHOOK_URL=
# IsolationForest anomaly score threshold (lower = more sensitive, range: -1 to 0)
ML_ANOMALY_THRESHOLD=-0.1
# Minimum samples collected before ML scoring activates (cold-start guard)
ML_MIN_SAMPLES=50
# Retrain IsolationForest model every N samples
ML_REFIT_EVERY=500
# Statistical Layer: fire alert if value deviates more than N * stddev from rolling mean
STAT_ZSCORE_THRESHOLD=3.0
# Rolling window size (number of samples) for statistical baseline
STAT_WINDOW_SIZE=100
